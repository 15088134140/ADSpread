{
  "name": "adspread-monorepo",
  "version": "1.3.0",
  "private": true,
  "description": "信发系统 - 门店广告投放展示系统",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm run dev --workspaces --if-present",
    "dev:backend": "pnpm run dev --workspace=@adspread/backend",
    "dev:admin": "pnpm run dev --workspace=@adspread/admin",
    "build": "pnpm run build --workspaces --if-present",
    "build:backend": "pnpm run build --workspace=@adspread/backend",
    "build:admin": "pnpm run build --workspace=@adspread/admin",
    "lint": "pnpm run lint --workspaces --if-present",
    "test": "pnpm run test --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "prepare": "husky install",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "prisma:generate": "pnpm run prisma:generate --workspace=@adspread/backend",
    "prisma:migrate": "pnpm run prisma:migrate --workspace=@adspread/backend"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js}": [
      "eslint --fix"
    ],
    "**/*.{ts,tsx,js,json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
